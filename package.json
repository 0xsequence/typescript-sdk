{
  "name": "typescript-sdk",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc && tsc -p tsconfig.esm.json && node scripts/write-esm-package.cjs",
    "dev:example": "pnpm --filter react-vite-example dev",
    "build:example": "pnpm --filter react-vite-example build",
    "node-example": "pnpm --filter node-example signIn",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "viem": "^2.48.4",
    "vitest": "^4.1.5"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "private": true
}
