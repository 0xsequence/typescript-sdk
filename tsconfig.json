{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["es2022", "dom"],
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "declaration": true,
    "outDir": "dist"
  },
  "include": ["src"]
}
